{
  "productName": "GENAI",
  "version": "0.1.1",
  "identifier": "com.genai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GENAI",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "minWidth": 900,
        "minHeight": 600,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5QjQ3RTU4QjdCNDdFOEMKUldTTWZyUzNXSDYwdWRGc3NGZDRYZXRtSC9nSkhGOHBpSXI3TTZSMm9DTDlWT0tzMjdEeTIyNTEK",
      "endpoints": [
        "https://github.com/jaewook0519/GENAI-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
